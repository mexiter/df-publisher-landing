APP_NAME="DataFlair Publisher Marketplace"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Production (this site): https://marketplace.dataflair.ai

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_DATABASE is optional for sqlite; defaults to database/database.sqlite

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# ---------------------------------------------------------------------------
# Mail — local: Mailpit (https://github.com/axllent/mailpit)
# Install and run Mailpit, then open the web UI (default http://127.0.0.1:8025).
# SMTP listens on 1025 by default.
# ---------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=
MAIL_FROM_ADDRESS=marketplace@dataflair.ai
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# Mail — production on marketplace.dataflair.ai: Resend (https://resend.com)
# APP_URL=https://marketplace.dataflair.ai
# Verify sending domain (e.g. dataflair.ai) in Resend; use an address on that domain below.
# ---------------------------------------------------------------------------
# MAIL_MAILER=resend
# RESEND_API_KEY=re_your_key_here
RESEND_API_KEY=

MARKETPLACE_PUBLIC_EMAIL=marketplace@dataflair.ai
MARKETPLACE_NOTIFY_EMAILS=

# Optional: HTTPS lookup via ipapi.co for public IPs (country, city, region, lat/lon).
# Cloudflare CF-IPCountry is stored without this. Respect rate limits / privacy policy.
MARKETPLACE_GEO_LOOKUP=false

# Optional: ISO 8601 launch instant for waitlist confirmation copy (e.g. 2026-06-01T09:00:00+00:00).
# Shown as a human “Launching in …” sentence at send time plus the absolute target line.
MARKETPLACE_LAUNCH_AT=

VITE_APP_NAME="${APP_NAME}"

# Inertia Laravel SSR (separate from Vite inertia({ ssr: false })). Keep off unless you run an SSR server.
INERTIA_SSR_ENABLED=false
